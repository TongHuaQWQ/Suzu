---
import { Icon } from "astro-icon/components";
import { site } from "../../site.config";
---

<nav
  class="flex p-4 items-center justify-between bg-(--md-surface-container-lowest) rounded-2xl shadow-sm w-full"
>
  <!-- 左侧：Logo/站点名称 -->
  <a href="/" class="flex items-center gap-2 font-bold text-(--md-on-surface)">
    <Icon name="gravity-ui:circle-fill" class="w-4 h-4 text-(--md-primary)" />
    <span>{site.title}</span>
  </a>

  <!-- 中间：主要导航链接 -->
  <ul class="hidden md:flex gap-1">
    {site.nav.map((item) => (
      <li>
        <a
          href={item.href}
          class="px-4 py-2 rounded-xl transition-colors hover:bg-(--md-primary-container) hover:text-(--md-on-primary-container) text-(--md-on-surface-variant)"
        >
          {item.label}
        </a>
      </li>
    ))}
  </ul>

  <!-- 右侧：图标按钮 -->
  <div class="flex gap-2">
    <button
      class="p-2 rounded-xl border border-(--md-outline-variant) hover:bg-(--md-surface-container-low) text-(--md-on-surface-variant) transition-colors"
    >
      <Icon name="mingcute:github-line" class="w-5 h-5" />
    </button>
    <button
      class="p-2 rounded-xl border border-(--md-outline-variant) hover:bg-(--md-surface-container-low) text-(--md-on-surface-variant) transition-colors"
    >
      <Icon name="gravity-ui:moon" class="w-5 h-5" />
    </button>
    <!-- 搜索容器 -->
    <div class="relative flex items-center">
      <!-- 搜索输入框：默认隐藏 (w-0 opacity-0)，点击后展开 -->
      <input
        type="text"
        id="searchInput"
        placeholder="搜索文章..."
        class="w-0 opacity-0 overflow-hidden rounded-xl border border-(--md-outline-variant) bg-(--md-surface-container-low) px-0 py-2 text-sm text-(--md-on-surface-variant) transition-all duration-300 ease-in-out focus:outline-none focus:ring-2 focus:ring-(--md-primary-container) peer"
      />

      <!-- 搜索按钮 -->
      <button
        id="searchBtn"
        class="ml-0 p-2 rounded-xl border border-(--md-outline-variant) hover:bg-(--md-surface-container-low) text-(--md-on-surface-variant) peer-focus:border-(--md-primary-container) transition-all duration-300"
      >
        <Icon name="mingcute:search-2-line" class="w-5 h-5" />
      </button>
    </div>
  </div>
</nav>

<script>
  const searchBtn = document.getElementById("searchBtn");
  const searchInput = document.getElementById("searchInput") as HTMLInputElement | null;
  if (!searchBtn || !searchInput) throw new Error("Search elements not found");

  let isOpen = false;

  function setSearch(open: boolean) {
    isOpen = open;
    searchInput!.classList.toggle("w-0", !open);
    searchInput!.classList.toggle("opacity-0", !open);
    searchInput!.classList.toggle("w-40", open);
    searchInput!.classList.toggle("px-3", open);
    searchInput!.classList.toggle("opacity-100", open);
    searchBtn!.classList.toggle("ml-0", !open);
    searchBtn!.classList.toggle("ml-2", open);
    open ? searchInput!.focus() : searchInput!.blur();
  }

  searchBtn.addEventListener("click", () => setSearch(!isOpen));
  document.addEventListener("click", (e) => {
    if (isOpen && !searchBtn.contains(e.target as Node) && !searchInput.contains(e.target as Node))
      setSearch(false);
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && isOpen) setSearch(false);
  });
</script>
