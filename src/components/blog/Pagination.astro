---
import { Icon } from "astro-icon/components";

interface Props {
  currentPage: number;
  lastPage: number;
  getPageUrl: (page: number) => string;
}

const { currentPage, lastPage, getPageUrl } = Astro.props;

function getPageNumbers(current: number, last: number): (number | "...")[] {
  if (last <= 5) return Array.from({ length: last }, (_, i) => i + 1);
  if (current <= 3) return [1, 2, 3, 4, "...", last];
  if (current >= last - 2)
    return [1, "...", last - 3, last - 2, last - 1, last];
  return [1, "...", current - 1, current, current + 1, "...", last];
}

const pageNumbers = getPageNumbers(currentPage, lastPage);
---

{
  lastPage > 1 && (
    <div class="mx-auto flex flex-row gap-3 justify-center">
      <!-- ← 上一页 -->
      <div class="bg-(--card-bg) flex flex-row rounded-lg items-center">
      {
        currentPage > 1 ? (
          <a
            href={getPageUrl(currentPage - 1)}
            aria-label="上一页"
            class="btn-card w-11 h-11 rounded-lg overflow-hidden"
          >
            <Icon
              name="gravity-ui:chevron-left"
              class="text-[1.75rem]"
            />
          </a>
        ) : (
          <span class="btn-card w-11 h-11 rounded-lg overflow-hidden disabled">
            <Icon
              name="gravity-ui:chevron-left"
              class="text-[1.75rem]"
            />
          </span>
        )
      }
      </div>

      <!-- 页码组 -->
      <div
        class="bg-(--card-bg) flex flex-row rounded-lg items-center
               text-neutral-700 dark:text-neutral-300 font-bold"
      >
        {
          pageNumbers.map((n) =>
            n === currentPage ? (
              <div
                class="h-11 w-11 rounded-lg bg-(--primary) flex items-center
                       justify-center font-bold text-white dark:text-black/70"
              >
                {n}
              </div>
            ) : n === "..." ? (
              <span
                class="w-11 h-11 flex items-center justify-center
                       text-(--md-on-surface-variant)"
              >
                ...
              </span>
            ) : (
              <a
                href={getPageUrl(n)}
                aria-label={`第 ${n} 页`}
                class="btn-card w-11 h-11 rounded-lg overflow-hidden active:scale-[0.85]"
              >
                {n}
              </a>
            )
          )
        }
      </div>

      <!-- → 下一页 -->
      <div class="bg-(--card-bg) flex flex-row rounded-lg items-center">
      {
        currentPage < lastPage ? (
          <a
            href={getPageUrl(currentPage + 1)}
            aria-label="下一页"
            class="btn-card w-11 h-11 rounded-lg overflow-hidden"
          >
            <Icon
              name="gravity-ui:chevron-right"
              class="text-[1.75rem]"
            />
          </a>
        ) : (
          <span class="btn-card w-11 h-11 rounded-lg overflow-hidden disabled">
            <Icon
              name="gravity-ui:chevron-right"
              class="text-[1.75rem]"
            />
          </span>
        )
      }
      </div>
    </div>
  )
}
