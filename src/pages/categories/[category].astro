---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import type { ImageMetadata } from "astro";
import SidebarLayout from "../../layouts/SidebarLayout.astro";
import PostList from "../../components/blog/PostList.astro";
import { getSortedPosts } from "../../utils/posts";

type BlogPost = CollectionEntry<"posts">;

const imageModules: Record<string, { default: ImageMetadata }> = import.meta.glob(
  "../../assets/**/*.{jpg,jpeg,png,webp,svg}",
  { eager: true },
);

export async function getStaticPaths() {
  const allPosts = await getCollection("posts");
  const allCategories = [
    ...new Set(allPosts.flatMap((p) => p.data.categories ?? [])),
  ];

  const paths = [];
  for (const category of allCategories) {
    const posts: BlogPost[] = await getSortedPosts(
      (p: BlogPost) => (p.data.categories ?? []).includes(category),
    );
    paths.push({ params: { category }, props: { category, posts } });
  }
  return paths;
}

const { category, posts } = Astro.props as { category: string; posts: BlogPost[] };
---

<SidebarLayout title={`分类: ${category}`}>
  <div class="flex items-center gap-2 mb-2">
    <h1 class="text-2xl font-bold text-(--md-on-surface)">分类</h1>
    <span
      class="px-3 py-1 text-sm rounded-lg bg-(--md-tertiary-container) text-(--md-on-tertiary-container)"
    >
      {category}
    </span>
    <span class="text-sm text-(--md-on-surface-variant)">
      ({posts.length} 篇)
    </span>
  </div>

  <PostList posts={posts} slugPrefix={`categories/${category}`} imageModules={imageModules} />
</SidebarLayout>
