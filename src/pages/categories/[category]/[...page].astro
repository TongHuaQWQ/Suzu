---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import type { ImageMetadata } from "astro";
import SidebarLayout from "../../../layouts/SidebarLayout.astro";
import PostList from "../../../components/blog/PostList.astro";
import Pagination from "../../../components/blog/Pagination.astro";
import { site } from "../../../site.config";

type BlogPost = CollectionEntry<"posts">;

const imageModules: Record<string, { default: ImageMetadata }> = import.meta.glob(
  "../../../assets/**/*.{jpg,jpeg,png,webp,svg}",
  { eager: true },
);

export async function getStaticPaths({ paginate }: { paginate: any }) {
  const PAGE_SIZE = site.ui.pageSize;
  const allPosts = await getCollection("posts");
  const allCategories = [
    ...new Set(allPosts.flatMap((p) => p.data.categories ?? [])),
  ];

  return allCategories.flatMap((category) => {
    const filtered = allPosts.filter((p) =>
      (p.data.categories ?? []).includes(category),
    );
    const sorted = filtered.sort(
      (a, b) =>
        new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
    );
    return paginate(sorted, {
      pageSize: PAGE_SIZE,
      params: { category },
    });
  });
}

const { page } = Astro.props;
const { category } = Astro.params;
const posts = page.data;
---

<SidebarLayout title={`分类: ${category}`}>
  <div class="flex items-center gap-2 mb-4">
    <h1 class="text-2xl font-bold text-(--md-on-surface)">分类</h1>
    <span
      class="px-3 py-1 text-sm rounded-lg bg-(--md-tertiary-container) text-(--md-on-tertiary-container)"
    >
      {category}
    </span>
    <span class="text-sm text-(--md-on-surface-variant)">
      ({page.total} 篇)
    </span>
  </div>

  <div class="flex flex-col gap-6">
    <PostList
      posts={posts}
      slugPrefix={`categories/${category}`}
      imageModules={imageModules}
    />
    <Pagination
      currentPage={page.currentPage}
      lastPage={page.lastPage}
      getPageUrl={(n: number) =>
        n === 1 ? `/categories/${category}/` : `/categories/${category}/${n}/`
      }
    />
  </div>
</SidebarLayout>
